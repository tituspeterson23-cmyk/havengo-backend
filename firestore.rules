rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth.token.email == 'thermypetson@gmail.com';
    }

    match /messages/{docId} {

      // Admin always reads. Otherwise: must be in participants,
      // OR the conversationId identifies this user (provider-admin-{email}
      // or customer-admin-{email}) — covers old messages with stale
      // participants arrays.
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.token.email in resource.data.participants ||
        resource.data.conversationId ==
          ('provider-admin-' + request.auth.token.email) ||
        resource.data.conversationId ==
          ('customer-admin-' + request.auth.token.email)
      );

      // Must be authenticated, sender must match your token,
      // and your email must be in the participants array
      allow create: if request.auth != null &&
        request.auth.token.email == request.resource.data.senderEmail &&
        request.auth.token.email in request.resource.data.participants;

      // Admin can delete any message; sender can delete their own
      allow delete: if request.auth != null && (
        isAdmin() ||
        request.auth.token.email == resource.data.senderEmail
      );

      // No editing
      allow update: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
